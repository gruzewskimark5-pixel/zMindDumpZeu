{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zlevelz.dev/schemas/task.json",
  "title": "Task",
  "description": "A task schema for ZLeveLZ",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "completed": {
      "type": "boolean"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["id", "title", "completed", "createdAt"],
  "additionalProperties": false
}
