{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zlevelz.dev/schemas/envelope.json",
  "title": "Envelope",
  "description": "Standard data envelope for ZLeveLZ",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string"
    },
    "data": {
      "type": "object"
    }
  },
  "required": ["version", "timestamp", "data"],
  "additionalProperties": false
}
