{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User",
  "description": "A simple user schema for demonstration",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "username": {
      "type": "string",
      "minLength": 3
    },
    "email": {
      "type": "string",
      "format": "email"
    }
  },
  "required": ["id", "username", "email"]
}
